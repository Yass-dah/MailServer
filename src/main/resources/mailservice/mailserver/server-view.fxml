<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="450.0" prefWidth="650.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mailservice.mailserver.controller.LogViewController">
  <top>
    <HBox alignment="CENTER_LEFT" prefHeight="50.0" spacing="10.0" BorderPane.alignment="CENTER">
      <children>
        <Label text="Logs:">
          <font>
            <Font name="System Bold" size="18.0" />
          </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Running" textFill="#02841a">
          <font>
            <Font name="System Bold" />
          </font>
        </Label>
      </children>
      <padding>
        <Insets left="20.0" right="20.0" />
      </padding>
    </HBox>
  </top>
  <center>
    <VBox BorderPane.alignment="CENTER">
      <children>
        <ListView fx:id="logList" style="-fx-background-color: #d8d8d8;" VBox.vgrow="ALWAYS" />
      </children>
      <padding>
        <Insets left="20.0" right="20.0" />
      </padding>
    </VBox>
  </center>
  <bottom>
    <VBox alignment="CENTER" prefHeight="70.0" spacing="10.0" BorderPane.alignment="CENTER">
      <children>
        <Separator prefWidth="200.0">
          <VBox.margin>
            <Insets bottom="5.0" />
          </VBox.margin>
        </Separator>
        <Button mnemonicParsing="false" onAction="#onStopButtonClick" prefHeight="30.0" prefWidth="150.0" text="STOP SERVER" textFill="#d70000">
          <font>
            <Font name="System Bold" />
          </font>
        </Button>
      </children>
      <padding>
        <Insets bottom="10.0" />
      </padding>
    </VBox>
  </bottom>
</BorderPane>